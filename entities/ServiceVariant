{
    "name": "ServiceVariant",
    "type": "object",
    "properties": {
        "service_id": {
            "type": "string"
        },
        "provider_id": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "type": {
            "type": "string",
            "enum": [
                "variant",
                "addon"
            ],
            "default": "addon",
            "description": "variant = mutually exclusive option, addon = stackable add-on"
        },
        "category": {
            "type": "string",
            "description": "e.g. haircut_style, beard, wash, styling"
        },
        "price_modifier": {
            "type": "number",
            "default": 0,
            "description": "Additional cost on top of base price"
        },
        "duration_modifier": {
            "type": "number",
            "default": 0,
            "description": "Additional minutes added to base duration"
        },
        "is_active": {
            "type": "boolean",
            "default": true
        },
        "sort_order": {
            "type": "number",
            "default": 0
        },
        "preparation_notes": {
            "type": "string",
            "description": "Instructions for the provider before this variant"
        },
        "requires_approval": {
            "type": "boolean",
            "default": false
        }
    },
    "required": [
        "service_id",
        "name"
    ]
}